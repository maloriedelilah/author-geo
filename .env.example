# Lead-capture secrets consumed by src/pages/api/subscribe.ts via the
# `cloudflare:workers` env import. Copy this file to `.env` for local dev
# (astro dev reads .env automatically) and set the same names as Cloudflare
# Pages secrets for production (never commit real values).
#
# Which adapter is active is a CONFIG option, not an env var — see
# src/config.ts -> siteConfig.leads.provider ('mailerlite' | 'emailoctopus').
# You only need to fill in the block matching your chosen provider.

# --- MailerLite (siteConfig.leads.provider = 'mailerlite') ---
MAILERLITE_API_KEY=

# --- EmailOctopus (siteConfig.leads.provider = 'emailoctopus') ---
EMAILOCTOPUS_API_KEY=
EMAILOCTOPUS_LIST_ID=

# Contact-form secrets consumed by src/pages/api/contact.ts (Tier 2, not yet
# written — see README "Contact form"). CONTACT_TO_EMAIL is your real inbox;
# it is NEVER read by the browser or committed anywhere, which is the whole
# point of routing the form through a server-side endpoint instead of a
# mailto: link or a visible email address in the page.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Optional but recommended once Tier 2 is wired: Cloudflare Turnstile to gate
# spam on the open-text contact form (the honeypot field in ContactForm.astro
# covers Tier 1's static shell, but Turnstile is the stronger layer for a live
# endpoint). TURNSTILE_SITE_KEY is public/embeddable, not actually a secret —
# it's listed here only for convenience alongside its secret counterpart.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
